<Window x:Class="PyHTML.WPF.Views.DeployWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:PyHTML.WPF.ViewModels"
        mc:Ignorable="d"
        Title="Cloudflare部署"
        Height="650"
        Width="800"
        MinHeight="550"
        MinWidth="700"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource Win11WindowStyle}">

    <Window.DataContext>
        <vm:DeployViewModel/>
    </Window.DataContext>

    <Border Background="{StaticResource WindowBackgroundBrush}"
            CornerRadius="12"
            BorderBrush="{StaticResource BorderLightBrush}"
            BorderThickness="1"
            Effect="{StaticResource WindowShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" 
                    Style="{StaticResource Win11TitleBarStyle}"
                    CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="16,0">
                        <TextBlock Text="&#xE774;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="18"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>
                        <TextBlock Text="Cloudflare部署"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="&#xE711;"
                            FontFamily="Segoe MDL2 Assets"
                            Style="{StaticResource Win11ToolButtonStyle}"
                            Width="46"
                            Height="32"
                            Click="CloseButton_Click"/>
                </Grid>
            </Border>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="24,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Panel - Settings -->
                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Text="部署设置"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,16"/>

                    <!-- Project Directory -->
                    <TextBlock Text="项目目录"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding ProjectDirectory, Mode=TwoWay}"
                                 Style="{StaticResource Win11TextBoxStyle}"
                                 IsReadOnly="True"/>
                        <Button Grid.Column="1"
                                Content="浏览..."
                                Style="{StaticResource Win11SecondaryButtonStyle}"
                                Command="{Binding BrowseDirectoryCommand}"
                                Padding="16,8"
                                Margin="8,0,0,0"/>
                    </Grid>
                    <TextBlock Text="选择部署项目的保存目录"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,4,0,16"/>

                    <!-- Worker Name -->
                    <TextBlock Text="Worker名称"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,8"/>
                    <TextBox Text="{Binding WorkerName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource Win11TextBoxStyle}"/>
                    <TextBlock Text="Cloudflare Worker的名称（只能包含小写字母、数字和连字符）"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,4,0,16"/>

                    <!-- Custom Domain -->
                    <TextBlock Text="自定义域名（可选）"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,8"/>
                    <TextBox Text="{Binding CustomDomain, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource Win11TextBoxStyle}"/>
                    <TextBlock Text="绑定自定义域名到 Worker"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,4,0,16"/>

                    <!-- Auto Deploy -->
                    <CheckBox IsChecked="{Binding AutoDeploy, Mode=TwoWay}"
                              Content="自动部署"
                              Foreground="{StaticResource TextPrimaryBrush}"
                              FontSize="13"
                              Margin="0,0,0,16"/>

                    <!-- API Token -->
                    <TextBlock Text="Cloudflare API Token"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,8"/>
                    <PasswordBox x:Name="ApiTokenPasswordBox"
                                 Style="{StaticResource Win11PasswordBoxStyle}"
                                 PasswordChanged="ApiTokenPasswordBox_PasswordChanged"/>
                    <TextBlock Text="用于自动部署的 API Token，可从 Cloudflare 控制台获取"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,4,0,16"/>

                    <!-- Deploy Button -->
                    <Button Content="开始部署"
                            Style="{StaticResource Win11PrimaryButtonStyle}"
                            Command="{Binding DeployCommand}"
                            IsEnabled="{Binding IsDeploying, Converter={StaticResource InverseBooleanConverter}}"
                            Padding="24,12"
                            FontSize="14"
                            HorizontalAlignment="Stretch"/>

                    <!-- Status -->
                    <Border Background="{Binding DeploySuccess, Converter={StaticResource BooleanToBrushConverter}, ConverterParameter=Success}"
                            CornerRadius="8"
                            Padding="12,8"
                            Visibility="{Binding DeployStatus, Converter={StaticResource StringToVisibilityConverter}}"
                            Margin="0,16,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding DeployStatus}"
                                       Foreground="{Binding DeploySuccess, Converter={StaticResource BooleanToBrushConverter}, ConverterParameter=Text}"
                                       TextWrapping="Wrap"/>
                            <Button Grid.Column="1"
                                    Content="打开"
                                    Style="{StaticResource Win11SecondaryButtonStyle}"
                                    Command="{Binding OpenDeployedUrlCommand}"
                                    Visibility="{Binding DeployedUrl, Converter={StaticResource StringToVisibilityConverter}}"
                                    Padding="12,6"
                                    FontSize="12"
                                    Margin="8,0,0,0"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- Right Panel - Logs -->
                <Border Grid.Column="1" 
                        Background="{StaticResource SurfaceBrush}"
                        CornerRadius="8"
                        BorderBrush="{StaticResource BorderLightBrush}"
                        BorderThickness="1"
                        Margin="12,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Log Header -->
                        <Border Grid.Row="0"
                                Background="{StaticResource SurfaceSecondaryBrush}"
                                CornerRadius="8,8,0,0"
                                BorderBrush="{StaticResource BorderLightBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="12,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="部署日志"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <Button Grid.Column="1"
                                        Content="&#xE74D;"
                                        FontFamily="Segoe MDL2 Assets"
                                        Style="{StaticResource Win11ToolButtonStyle}"
                                        Command="{Binding ClearLogsCommand}"
                                        ToolTip="清空日志"
                                        Width="28"
                                        Height="28"/>
                            </Grid>
                        </Border>

                        <!-- Log Content -->
                        <ScrollViewer Grid.Row="1"
                                      Style="{StaticResource Win11ScrollViewerStyle}"
                                      Padding="12">
                            <ItemsControl ItemsSource="{Binding Logs}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal"
                                                    Margin="0,2">
                                            <TextBlock Text="{Binding Timestamp, StringFormat=HH:mm:ss}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontFamily="Consolas, monospace"
                                                       Width="60"/>
                                            <TextBlock Text="{Binding Message}"
                                                       FontSize="12"
                                                       Foreground="{Binding IsError, Converter={StaticResource BooleanToBrushConverter}, ConverterParameter=Text}"
                                                       FontFamily="Consolas, monospace"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <!-- Status Bar -->
            <Border Grid.Row="2" 
                    Background="{StaticResource SurfaceSecondaryBrush}"
                    BorderBrush="{StaticResource BorderLightBrush}"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,12,12"
                    Padding="16,10">
                <TextBlock Text="部署到 Cloudflare Workers，实现快速全球访问"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12"/>
            </Border>
        </Grid>
    </Border>
</Window>
