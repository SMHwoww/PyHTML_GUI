<Window x:Class="PyHTML.WPF.Views.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="使用说明"
        Height="600"
        Width="700"
        MinHeight="500"
        MinWidth="600"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource Win11WindowStyle}">

    <Border Background="{StaticResource WindowBackgroundBrush}"
            CornerRadius="12"
            BorderBrush="{StaticResource BorderLightBrush}"
            BorderThickness="1"
            Effect="{StaticResource WindowShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" 
                    Style="{StaticResource Win11TitleBarStyle}"
                    CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="16,0">
                        <TextBlock Text="&#xE897;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="18"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>
                        <TextBlock Text="使用说明"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="&#xE711;"
                            FontFamily="Segoe MDL2 Assets"
                            Style="{StaticResource Win11ToolButtonStyle}"
                            Width="46"
                            Height="32"
                            Click="CloseButton_Click"/>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" 
                          Style="{StaticResource Win11ScrollViewerStyle}"
                          Margin="24,16">
                <StackPanel>
                    <TextBlock Text="pyHTML - 组件化HTML生成器"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="版本 v0.6.0 (.NET WPF Edition)"
                               FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,24"/>

                    <!-- Quick Start -->
                    <TextBlock Text="快速开始"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,12"/>
                    <Border Background="{StaticResource SurfaceBrush}"
                            CornerRadius="8"
                            BorderBrush="{StaticResource BorderLightBrush}"
                            BorderThickness="1"
                            Padding="16"
                            Margin="0,0,0,24">
                        <StackPanel>
                            <TextBlock Text="1. 从左侧组件库双击或拖拽组件到中间页面区域"
                                       FontSize="13"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,4"/>
                            <TextBlock Text="2. 在右侧属性面板编辑组件属性"
                                       FontSize="13"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,4"/>
                            <TextBlock Text="3. 点击预览按钮查看效果"
                                       FontSize="13"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,4"/>
                            <TextBlock Text="4. 导出HTML或部署到Cloudflare"
                                       FontSize="13"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,4"/>
                        </StackPanel>
                    </Border>

                    <!-- Features -->
                    <TextBlock Text="主要功能"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,12"/>
                    <Border Background="{StaticResource SurfaceBrush}"
                            CornerRadius="8"
                            BorderBrush="{StaticResource BorderLightBrush}"
                            BorderThickness="1"
                            Padding="16"
                            Margin="0,0,0,24">
                        <StackPanel>
                            <TextBlock Text="• 组件化设计 - 拖拽式组件库，快速构建页面"
                                       FontSize="13"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,4"/>
                            <TextBlock Text="• AI助手 - 智能生成和优化组件"
                                       FontSize="13"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,4"/>
                            <TextBlock Text="• 图片管理 - 云端图床，一键上传"
                                       FontSize="13"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,4"/>
                            <TextBlock Text="• Cloudflare部署 - 一键部署到全球CDN"
                                       FontSize="13"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,4"/>
                            <TextBlock Text="• 实时预览 - 即时查看页面效果"
                                       FontSize="13"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,4"/>
                        </StackPanel>
                    </Border>

                    <!-- Tips -->
                    <TextBlock Text="使用技巧"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,12"/>
                    <Border Background="{StaticResource SurfaceBrush}"
                            CornerRadius="8"
                            BorderBrush="{StaticResource BorderLightBrush}"
                            BorderThickness="1"
                            Padding="16"
                            Margin="0,0,0,24">
                        <StackPanel>
                            <TextBlock Text="• 使用快捷键 Ctrl+C / Ctrl+V 复制粘贴组件"
                                       FontSize="13"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,4"/>
                            <TextBlock Text="• 按 Delete 键删除选中组件"
                                       FontSize="13"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,4"/>
                            <TextBlock Text="• 拖拽组件可调整顺序"
                                       FontSize="13"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,4"/>
                            <TextBlock Text="• 右键点击组件可使用AI优化"
                                       FontSize="13"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,4"/>
                        </StackPanel>
                    </Border>

                    <!-- Contact -->
                    <TextBlock Text="获取帮助"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,12"/>
                    <Border Background="{StaticResource SurfaceBrush}"
                            CornerRadius="8"
                            BorderBrush="{StaticResource BorderLightBrush}"
                            BorderThickness="1"
                            Padding="16">
                        <StackPanel>
                            <TextBlock Text="如有问题或建议，欢迎反馈："
                                       FontSize="13"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,4"/>
                            <TextBlock Text="GitHub: https://github.com/pyhtml/pyhtml-gui"
                                       FontSize="13"
                                       Foreground="{StaticResource PrimaryBrush}"
                                       Margin="0,4"
                                       Cursor="Hand"
                                       MouseLeftButtonDown="GitHubLink_MouseLeftButtonDown"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Status Bar -->
            <Border Grid.Row="2" 
                    Background="{StaticResource SurfaceSecondaryBrush}"
                    BorderBrush="{StaticResource BorderLightBrush}"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,12,12"
                    Padding="16,10">
                <TextBlock Text="pyHTML - 让网页制作更简单"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12"/>
            </Border>
        </Grid>
    </Border>
</Window>
