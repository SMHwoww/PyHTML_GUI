<Window x:Class="PyHTML.WPF.Views.AIConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:PyHTML.WPF.ViewModels"
        mc:Ignorable="d"
        Title="AI配置"
        Height="500"
        Width="550"
        MinHeight="450"
        MinWidth="500"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource Win11WindowStyle}">

    <Window.DataContext>
        <vm:AIConfigViewModel/>
    </Window.DataContext>

    <Border Background="{StaticResource WindowBackgroundBrush}"
            CornerRadius="12"
            BorderBrush="{StaticResource BorderLightBrush}"
            BorderThickness="1"
            Effect="{StaticResource WindowShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" 
                    Style="{StaticResource Win11TitleBarStyle}"
                    CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="AI配置"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center"
                               Margin="16,0"/>

                    <Button Grid.Column="1"
                            Content="&#xE711;"
                            FontFamily="Segoe MDL2 Assets"
                            Style="{StaticResource Win11ToolButtonStyle}"
                            Width="46"
                            Height="32"
                            Click="CloseButton_Click"/>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" 
                          Style="{StaticResource Win11ScrollViewerStyle}"
                          Margin="24,16">
                <StackPanel>
                    <!-- API Key -->
                    <TextBlock Text="API Key"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <PasswordBox Grid.Column="0"
                                     x:Name="ApiKeyPasswordBox"
                                     Style="{StaticResource Win11PasswordBoxStyle}"
                                     PasswordChanged="ApiKeyPasswordBox_PasswordChanged"/>
                        <Button Grid.Column="1"
                                Content="&#xE7B3;"
                                FontFamily="Segoe MDL2 Assets"
                                Style="{StaticResource Win11ToolButtonStyle}"
                                Margin="8,0,0,0"
                                Click="TogglePasswordVisibility_Click"/>
                    </Grid>
                    <TextBlock Text="您的阿里云 DashScope API Key"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,4,0,16"/>

                    <!-- API Base URL -->
                    <TextBlock Text="API地址"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,8"/>
                    <TextBox Text="{Binding BaseUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource Win11TextBoxStyle}"/>
                    <TextBlock Text="API 请求的基础地址"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,4,0,16"/>

                    <!-- Model Selection -->
                    <TextBlock Text="模型"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,8"/>
                    <ComboBox ItemsSource="{Binding AvailableModels}"
                              SelectedItem="{Binding SelectedModel, Mode=TwoWay}"
                              Style="{StaticResource Win11ComboBoxStyle}"/>
                    <TextBlock Text="选择要使用的 AI 模型"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,4,0,16"/>

                    <!-- Max Tokens -->
                    <TextBlock Text="Tokens最大值"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,8"/>
                    <TextBox Text="{Binding MaxTokens, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource Win11TextBoxStyle}"/>
                    <TextBlock Text="单次请求的最大 token 数"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,4,0,16"/>

                    <!-- Test Result -->
                    <Border Background="{Binding TestResultIsError, Converter={StaticResource BooleanToBrushConverter}, ConverterParameter=Error}"
                            CornerRadius="8"
                            Padding="12,8"
                            Visibility="{Binding TestResult, Converter={StaticResource StringToVisibilityConverter}}"
                            Margin="0,8,0,0">
                        <TextBlock Text="{Binding TestResult}"
                                   Foreground="{Binding TestResultIsError, Converter={StaticResource BooleanToBrushConverter}, ConverterParameter=Text}"
                                   TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Buttons -->
            <Border Grid.Row="2" 
                    Background="{StaticResource SurfaceSecondaryBrush}"
                    BorderBrush="{StaticResource BorderLightBrush}"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,12,12"
                    Padding="24,16">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="测试连接"
                            Style="{StaticResource Win11SecondaryButtonStyle}"
                            Command="{Binding TestConnectionCommand}"
                            IsEnabled="{Binding IsTesting, Converter={StaticResource InverseBooleanConverter}}"/>
                    <Button Content="保存配置"
                            Style="{StaticResource Win11PrimaryButtonStyle}"
                            Command="{Binding SaveConfigCommand}"
                            Margin="12,0,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
