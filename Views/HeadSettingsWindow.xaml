<Window x:Class="PyHTML.WPF.Views.HeadSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:PyHTML.WPF.ViewModels"
        mc:Ignorable="d"
        Title="Head设置"
        Height="600"
        Width="800"
        MinHeight="500"
        MinWidth="700"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource Win11WindowStyle}">

    <Window.DataContext>
        <vm:HeadSettingsViewModel/>
    </Window.DataContext>

    <Border Background="{StaticResource WindowBackgroundBrush}"
            CornerRadius="12"
            BorderBrush="{StaticResource BorderLightBrush}"
            BorderThickness="1"
            Effect="{StaticResource WindowShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" 
                    Style="{StaticResource Win11TitleBarStyle}"
                    CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="16,0">
                        <TextBlock Text="&#xE737;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="18"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>
                        <TextBlock Text="Head设置"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="&#xE711;"
                            FontFamily="Segoe MDL2 Assets"
                            Style="{StaticResource Win11ToolButtonStyle}"
                            Width="46"
                            Height="32"
                            Click="CloseButton_Click"/>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" 
                          Style="{StaticResource Win11ScrollViewerStyle}"
                          Margin="24,16">
                <StackPanel>
                    <!-- Basic Settings -->
                    <TextBlock Text="基本设置"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,16"/>

                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                            <TextBlock Text="页面标题"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,0,0,8"/>
                            <TextBox Text="{Binding PageTitle, Mode=TwoWay}"
                                     Style="{StaticResource Win11TextBoxStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <TextBlock Text="语言"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,0,0,8"/>
                            <TextBox Text="{Binding Language, Mode=TwoWay}"
                                     Style="{StaticResource Win11TextBoxStyle}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Quick Add -->
                    <TextBlock Text="快捷添加"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,12"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                        <Button Content="&#xE737; 添加网站图标"
                                Style="{StaticResource Win11SecondaryButtonStyle}"
                                Command="{Binding AddFaviconCommand}"
                                Padding="16,8"
                                FontSize="13"/>
                        <Button Content="&#xE8B1; 添加描述"
                                Style="{StaticResource Win11SecondaryButtonStyle}"
                                Command="{Binding AddDescriptionCommand}"
                                Padding="16,8"
                                FontSize="13"
                                Margin="8,0,0,0"/>
                        <Button Content="&#xE8A1; 添加关键词"
                                Style="{StaticResource Win11SecondaryButtonStyle}"
                                Command="{Binding AddKeywordsCommand}"
                                Padding="16,8"
                                FontSize="13"
                                Margin="8,0,0,0"/>
                    </StackPanel>

                    <!-- Meta Tags -->
                    <TextBlock Text="Meta标签"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,12"/>
                    <Border Background="{StaticResource SurfaceBrush}"
                            CornerRadius="8"
                            BorderBrush="{StaticResource BorderLightBrush}"
                            BorderThickness="1"
                            Padding="12"
                            Margin="0,0,0,16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <ListBox Grid.Row="0"
                                     ItemsSource="{Binding MetaTags}"
                                     SelectedItem="{Binding SelectedMetaTag}"
                                     Style="{StaticResource Win11ListBoxStyle}"
                                     Height="120"
                                     Margin="0,0,0,8">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0"
                                                     Text="{Binding Name, Mode=TwoWay}"
                                                     Style="{StaticResource Win11TextBoxStyle}"
                                                     FontSize="12"
                                                     Padding="8,6"
                                                     Margin="0,0,4,0"/>
                                            <TextBox Grid.Column="1"
                                                     Text="{Binding Content, Mode=TwoWay}"
                                                     Style="{StaticResource Win11TextBoxStyle}"
                                                     FontSize="12"
                                                     Padding="8,6"
                                                     Margin="4,0,0,0"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <StackPanel Grid.Row="1" Orientation="Horizontal">
                                <Button Content="&#xE710; 添加"
                                        Style="{StaticResource Win11SecondaryButtonStyle}"
                                        Command="{Binding AddMetaTagCommand}"
                                        Padding="12,6"
                                        FontSize="12"/>
                                <Button Content="&#xE74D; 删除"
                                        Style="{StaticResource Win11SecondaryButtonStyle}"
                                        Command="{Binding RemoveMetaTagCommand}"
                                        IsEnabled="{Binding SelectedMetaTag, Converter={StaticResource NullToBooleanConverter}}"
                                        Padding="12,6"
                                        FontSize="12"
                                        Margin="8,0,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Link Tags -->
                    <TextBlock Text="Link标签"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,12"/>
                    <Border Background="{StaticResource SurfaceBrush}"
                            CornerRadius="8"
                            BorderBrush="{StaticResource BorderLightBrush}"
                            BorderThickness="1"
                            Padding="12"
                            Margin="0,0,0,16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <ListBox Grid.Row="0"
                                     ItemsSource="{Binding LinkTags}"
                                     SelectedItem="{Binding SelectedLinkTag}"
                                     Style="{StaticResource Win11ListBoxStyle}"
                                     Height="100"
                                     Margin="0,0,0,8">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0"
                                                     Text="{Binding Rel, Mode=TwoWay}"
                                                     Style="{StaticResource Win11TextBoxStyle}"
                                                     FontSize="12"
                                                     Padding="8,6"
                                                     Width="100"
                                                     Margin="0,0,4,0"/>
                                            <TextBox Grid.Column="1"
                                                     Text="{Binding Href, Mode=TwoWay}"
                                                     Style="{StaticResource Win11TextBoxStyle}"
                                                     FontSize="12"
                                                     Padding="8,6"
                                                     Margin="4,0,0,0"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <StackPanel Grid.Row="1" Orientation="Horizontal">
                                <Button Content="&#xE710; 添加"
                                        Style="{StaticResource Win11SecondaryButtonStyle}"
                                        Command="{Binding AddLinkTagCommand}"
                                        Padding="12,6"
                                        FontSize="12"/>
                                <Button Content="&#xE74D; 删除"
                                        Style="{StaticResource Win11SecondaryButtonStyle}"
                                        Command="{Binding RemoveLinkTagCommand}"
                                        IsEnabled="{Binding SelectedLinkTag, Converter={StaticResource NullToBooleanConverter}}"
                                        Padding="12,6"
                                        FontSize="12"
                                        Margin="8,0,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Script Tags -->
                    <TextBlock Text="Script标签"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,12"/>
                    <Border Background="{StaticResource SurfaceBrush}"
                            CornerRadius="8"
                            BorderBrush="{StaticResource BorderLightBrush}"
                            BorderThickness="1"
                            Padding="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <ListBox Grid.Row="0"
                                     ItemsSource="{Binding ScriptTags}"
                                     SelectedItem="{Binding SelectedScriptTag}"
                                     Style="{StaticResource Win11ListBoxStyle}"
                                     Height="100"
                                     Margin="0,0,0,8">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding Src, Mode=TwoWay}"
                                                 Style="{StaticResource Win11TextBoxStyle}"
                                                 FontSize="12"
                                                 Padding="8,6"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <StackPanel Grid.Row="1" Orientation="Horizontal">
                                <Button Content="&#xE710; 添加"
                                        Style="{StaticResource Win11SecondaryButtonStyle}"
                                        Command="{Binding AddScriptTagCommand}"
                                        Padding="12,6"
                                        FontSize="12"/>
                                <Button Content="&#xE74D; 删除"
                                        Style="{StaticResource Win11SecondaryButtonStyle}"
                                        Command="{Binding RemoveScriptTagCommand}"
                                        IsEnabled="{Binding SelectedScriptTag, Converter={StaticResource NullToBooleanConverter}}"
                                        Padding="12,6"
                                        FontSize="12"
                                        Margin="8,0,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Buttons -->
            <Border Grid.Row="2" 
                    Background="{StaticResource SurfaceSecondaryBrush}"
                    BorderBrush="{StaticResource BorderLightBrush}"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,12,12"
                    Padding="24,16">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="保存设置"
                            Style="{StaticResource Win11PrimaryButtonStyle}"
                            Command="{Binding SaveSettingsCommand}"
                            Padding="24,10"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
