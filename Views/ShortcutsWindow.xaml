<Window x:Class="PyHTML.WPF.Views.ShortcutsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="快捷键"
        Height="500"
        Width="500"
        MinHeight="400"
        MinWidth="400"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource Win11WindowStyle}">

    <Border Background="{StaticResource WindowBackgroundBrush}"
            CornerRadius="12"
            BorderBrush="{StaticResource BorderLightBrush}"
            BorderThickness="1"
            Effect="{StaticResource WindowShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" 
                    Style="{StaticResource Win11TitleBarStyle}"
                    CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="16,0">
                        <TextBlock Text="&#xE765;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="18"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>
                        <TextBlock Text="快捷键"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="&#xE711;"
                            FontFamily="Segoe MDL2 Assets"
                            Style="{StaticResource Win11ToolButtonStyle}"
                            Width="46"
                            Height="32"
                            Click="CloseButton_Click"/>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" 
                          Style="{StaticResource Win11ScrollViewerStyle}"
                          Margin="24,16">
                <StackPanel>
                    <TextBlock Text="键盘快捷键"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,16"/>

                    <!-- File Shortcuts -->
                    <TextBlock Text="文件操作"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,12"/>
                    <Border Background="{StaticResource SurfaceBrush}"
                            CornerRadius="8"
                            BorderBrush="{StaticResource BorderLightBrush}"
                            BorderThickness="1"
                            Padding="16"
                            Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="新建项目" Margin="0,4"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="Ctrl+N" FontFamily="Consolas" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="打开项目" Margin="0,4"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="Ctrl+O" FontFamily="Consolas" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="保存项目" Margin="0,4"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="Ctrl+S" FontFamily="Consolas" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="导出HTML" Margin="0,4"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="Ctrl+E" FontFamily="Consolas" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4"/>
                        </Grid>
                    </Border>

                    <!-- Edit Shortcuts -->
                    <TextBlock Text="编辑操作"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,12"/>
                    <Border Background="{StaticResource SurfaceBrush}"
                            CornerRadius="8"
                            BorderBrush="{StaticResource BorderLightBrush}"
                            BorderThickness="1"
                            Padding="16"
                            Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="复制组件" Margin="0,4"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="Ctrl+C" FontFamily="Consolas" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="粘贴组件" Margin="0,4"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="Ctrl+V" FontFamily="Consolas" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="删除组件" Margin="0,4"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="Delete" FontFamily="Consolas" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="上移组件" Margin="0,4"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="Ctrl+Up" FontFamily="Consolas" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4"/>
                        </Grid>
                    </Border>

                    <!-- View Shortcuts -->
                    <TextBlock Text="视图操作"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,12"/>
                    <Border Background="{StaticResource SurfaceBrush}"
                            CornerRadius="8"
                            BorderBrush="{StaticResource BorderLightBrush}"
                            BorderThickness="1"
                            Padding="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="预览" Margin="0,4"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="F5" FontFamily="Consolas" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="打开快捷键帮助" Margin="0,4"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="F1" FontFamily="Consolas" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Status Bar -->
            <Border Grid.Row="2" 
                    Background="{StaticResource SurfaceSecondaryBrush}"
                    BorderBrush="{StaticResource BorderLightBrush}"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,12,12"
                    Padding="16,10">
                <TextBlock Text="使用快捷键可以提高工作效率"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12"/>
            </Border>
        </Grid>
    </Border>
</Window>
