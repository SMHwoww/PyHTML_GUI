<Window x:Class="PyHTML.WPF.Views.AIDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:PyHTML.WPF.ViewModels"
        mc:Ignorable="d"
        Title="AI对话"
        Height="700"
        Width="800"
        MinHeight="500"
        MinWidth="600"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource Win11WindowStyle}">

    <Window.DataContext>
        <vm:AIDialogViewModel/>
    </Window.DataContext>

    <Border Background="{StaticResource WindowBackgroundBrush}"
            CornerRadius="12"
            BorderBrush="{StaticResource BorderLightBrush}"
            BorderThickness="1"
            Effect="{StaticResource WindowShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" 
                    Style="{StaticResource Win11TitleBarStyle}"
                    CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="16,0">
                        <TextBlock Text="&#xE99A;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="18"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>
                        <TextBlock Text="AI对话助手"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="&#xE71C;"
                                FontFamily="Segoe MDL2 Assets"
                                Style="{StaticResource Win11ToolButtonStyle}"
                                ToolTip="生成组件"
                                Command="{Binding GenerateComponentCommand}"
                                Width="46"
                                Height="32"/>
                        <Button Content="&#xE74D;"
                                FontFamily="Segoe MDL2 Assets"
                                Style="{StaticResource Win11ToolButtonStyle}"
                                ToolTip="清空对话"
                                Command="{Binding ClearChatCommand}"
                                Width="46"
                                Height="32"/>
                        <Button Content="&#xE711;"
                                FontFamily="Segoe MDL2 Assets"
                                Style="{StaticResource Win11ToolButtonStyle}"
                                Width="46"
                                Height="32"
                                Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Chat Messages -->
            <Border Grid.Row="1" 
                    Background="{StaticResource SurfaceBrush}"
                    Margin="16,8,16,0"
                    CornerRadius="8"
                    BorderBrush="{StaticResource BorderLightBrush}"
                    BorderThickness="1">
                <ScrollViewer x:Name="MessagesScrollViewer"
                              Style="{StaticResource Win11ScrollViewerStyle}"
                              Padding="12">
                    <ItemsControl ItemsSource="{Binding Messages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,8"
                                        Padding="12,10"
                                        CornerRadius="8"
                                        Background="{Binding Role, Converter={StaticResource RoleToBrushConverter}}"
                                        HorizontalAlignment="{Binding Role, Converter={StaticResource RoleToAlignmentConverter}}"
                                        MaxWidth="600">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        
                                        <!-- Header -->
                                        <StackPanel Grid.Row="0" 
                                                    Orientation="Horizontal"
                                                    Margin="0,0,0,6">
                                            <TextBlock Text="{Binding Role, Converter={StaticResource RoleToDisplayConverter}}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{Binding IsError, Converter={StaticResource BooleanToBrushConverter}, ConverterParameter=ErrorText}"/>
                                            <TextBlock Text="{Binding Timestamp, StringFormat=HH:mm}"
                                                       FontSize="10"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Margin="8,0,0,0"/>
                                        </StackPanel>
                                        
                                        <!-- Content -->
                                        <TextBlock Grid.Row="1"
                                                   Text="{Binding Content}"
                                                   TextWrapping="Wrap"
                                                   Foreground="{Binding IsError, Converter={StaticResource BooleanToBrushConverter}, ConverterParameter=Text}"
                                                   FontSize="13"
                                                   LineHeight="20"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <!-- Input Area -->
            <Grid Grid.Row="2" Margin="16,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Text="{Binding UserInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource Win11TextBoxStyle}"
                         Padding="16,12"
                         FontSize="14"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         MaxHeight="120"
                         VerticalScrollBarVisibility="Auto">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Return" 
                                    Modifiers="Ctrl"
                                    Command="{Binding SendMessageCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>

                <Button Grid.Column="1"
                        Content="&#xE724;"
                        FontFamily="Segoe MDL2 Assets"
                        Style="{StaticResource Win11PrimaryButtonStyle}"
                        Command="{Binding SendMessageCommand}"
                        IsEnabled="{Binding IsSending, Converter={StaticResource InverseBooleanConverter}}"
                        Width="56"
                        Height="48"
                        Margin="12,0,0,0"
                        FontSize="18"/>
            </Grid>

            <!-- Status Bar -->
            <Border Grid.Row="3" 
                    Background="{StaticResource SurfaceSecondaryBrush}"
                    BorderBrush="{StaticResource BorderLightBrush}"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,12,12"
                    Padding="16,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="{Binding StatusText}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="●"
                                   Foreground="{Binding HasApiKey, Converter={StaticResource BooleanToBrushConverter}, ConverterParameter=Success}"
                                   FontSize="8"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="配置"
                            Style="{StaticResource Win11SecondaryButtonStyle}"
                            Command="{Binding OpenConfigCommand}"
                            Padding="16,6"
                            FontSize="12"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
