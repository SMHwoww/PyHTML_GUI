<Window x:Class="PyHTML.WPF.Views.ImageSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:PyHTML.WPF.ViewModels"
        mc:Ignorable="d"
        Title="图片设置"
        Height="450"
        Width="550"
        MinHeight="400"
        MinWidth="500"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource Win11WindowStyle}">

    <Window.DataContext>
        <vm:ImageSettingsViewModel/>
    </Window.DataContext>

    <Border Background="{StaticResource WindowBackgroundBrush}"
            CornerRadius="12"
            BorderBrush="{StaticResource BorderLightBrush}"
            BorderThickness="1"
            Effect="{StaticResource WindowShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" 
                    Style="{StaticResource Win11TitleBarStyle}"
                    CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="16,0">
                        <TextBlock Text="&#xE91B;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="18"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>
                        <TextBlock Text="图片设置"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="&#xE711;"
                            FontFamily="Segoe MDL2 Assets"
                            Style="{StaticResource Win11ToolButtonStyle}"
                            Width="46"
                            Height="32"
                            Click="CloseButton_Click"/>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" 
                          Style="{StaticResource Win11ScrollViewerStyle}"
                          Margin="24,16">
                <StackPanel>
                    <!-- Description -->
                    <TextBlock Text="图片上传服务配置"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="配置图床API Token，用于上传和管理图片。"
                               FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,24"/>

                    <!-- API Token -->
                    <TextBlock Text="API Token"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,8"/>
                    <PasswordBox x:Name="ApiTokenPasswordBox"
                                 Style="{StaticResource Win11PasswordBoxStyle}"
                                 PasswordChanged="ApiTokenPasswordBox_PasswordChanged"/>
                    <TextBlock Text="您的图床 API Token，用于上传图片"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,4,0,16"/>

                    <!-- Service Info -->
                    <Border Background="{StaticResource SurfaceSecondaryBrush}"
                            CornerRadius="8"
                            Padding="16"
                            Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="服务信息"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="• 支持格式: JPG, PNG, GIF, WEBP"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,2"/>
                            <TextBlock Text="• 单文件最大: 5MB"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,2"/>
                            <TextBlock Text="• Token有效期: 1小时"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,2"/>
                        </StackPanel>
                    </Border>

                    <!-- Test Result -->
                    <Border Background="{Binding TestResultIsError, Converter={StaticResource BooleanToBrushConverter}, ConverterParameter=Error}"
                            CornerRadius="8"
                            Padding="12,8"
                            Visibility="{Binding TestResult, Converter={StaticResource StringToVisibilityConverter}}"
                            Margin="0,8,0,0">
                        <TextBlock Text="{Binding TestResult}"
                                   Foreground="{Binding TestResultIsError, Converter={StaticResource BooleanToBrushConverter}, ConverterParameter=Text}"
                                   TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Buttons -->
            <Border Grid.Row="2" 
                    Background="{StaticResource SurfaceSecondaryBrush}"
                    BorderBrush="{StaticResource BorderLightBrush}"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,12,12"
                    Padding="24,16">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="测试连接"
                            Style="{StaticResource Win11SecondaryButtonStyle}"
                            Command="{Binding TestConnectionCommand}"
                            IsEnabled="{Binding IsTesting, Converter={StaticResource InverseBooleanConverter}}"/>
                    <Button Content="保存设置"
                            Style="{StaticResource Win11PrimaryButtonStyle}"
                            Command="{Binding SaveSettingsCommand}"
                            Margin="12,0,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
