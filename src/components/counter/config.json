{
  "name": "counter",
  "display_name": "计数器",
  "description": "一个可配置的计数器组件",
  "version": "1.0.0",
  "author": "PyHTML GUI",
  "fields": [
    {
      "name": "initial_value",
      "type": "number",
      "label": "初始值",
      "default": 0,
      "min": 0,
      "step": 1
    },
    {
      "name": "step",
      "type": "number",
      "label": "步长",
      "default": 1,
      "min": 1,
      "step": 1
    },
    {
      "name": "min_value",
      "type": "number",
      "label": "最小值",
      "default": 0,
      "step": 1
    },
    {
      "name": "max_value",
      "type": "number",
      "label": "最大值",
      "default": 100,
      "step": 1
    },
    {
      "name": "button_color",
      "type": "color",
      "label": "按钮颜色",
      "default": "#4CAF50"
    },
    {
      "name": "text_color",
      "type": "color",
      "label": "文本颜色",
      "default": "#333333"
    },
    {
      "name": "button_size",
      "type": "number",
      "label": "按钮大小",
      "default": 36,
      "min": 20,
      "max": 60,
      "step": 2
    },
    {
      "name": "alignment",
      "type": "select",
      "label": "对齐方式",
      "default": "left",
      "options": [
        {"value": "left", "label": "左对齐"},
        {"value": "center", "label": "居中"},
        {"value": "right", "label": "右对齐"}
      ]
    }
  ]
}