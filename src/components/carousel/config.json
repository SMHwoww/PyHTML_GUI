{
  "name": "carousel",
  "display_name": "轮播图",
  "category": "媒体",
  "fields": [
    {
      "name": "images",
      "type": "pictures",
      "label": "图片URL",
      "default": "https://upload-bbs.miyoushe.com/upload/2026/02/05/288909600/70642da7de8c6106af492c754a34bc4d_6139057021720985156.jpg?x-oss-process=image/resize,s_300/quality,q_80/auto-orient,0/interlace,1/format,jpg\nhttps://upload-bbs.miyoushe.com/upload/2026/02/04/288909600/86092d7f6e08d8735a423c68e542c81a_4025614547561242667.png?x-oss-process=image/resize,s_300/quality,q_80/auto-orient,0/interlace,1/format,jpg\nhttps://upload-bbs.miyoushe.com/upload/2025/11/21/310734234/50fa304afa9fc4b1be092bc16a384906_2878578656610514158.png?x-oss-process=image/resize,s_600/quality,q_80/auto-orient,0/interlace,1/format,png",
      "placeholder": "每行一个图片URL"
    },
    {
      "name": "autoplay",
      "type": "boolean",
      "label": "自动播放",
      "default": true
    },
    {
      "name": "interval",
      "type": "number",
      "label": "播放间隔(毫秒)",
      "default": 5000,
      "min": 1000,
      "max": 30000
    },
    {
      "name": "show_controls",
      "type": "boolean",
      "label": "显示控制按钮",
      "default": true
    },
    {
      "name": "show_indicators",
      "type": "boolean",
      "label": "显示指示器",
      "default": true
    },
    {
      "name": "width",
      "type": "number",
      "label": "宽度(px)",
      "default": 800,
      "min": 200,
      "max": 1200
    },
    {
      "name": "height",
      "type": "number",
      "label": "高度(px)",
      "default": 450,
      "min": 100,
      "max": 800
    },
    {
      "name": "alignment",
      "type": "select",
      "label": "对齐方式",
      "default": "center",
      "options": [
        {"value": "left", "label": "左对齐"},
        {"value": "center", "label": "居中"},
        {"value": "right", "label": "右对齐"}
      ]
    }
  ]
}