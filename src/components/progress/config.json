{
  "name": "progress",
  "display_name": "进度条",
  "description": "一个可配置的进度条组件",
  "version": "1.0.0",
  "author": "PyHTML GUI",
  "fields": [
    {
      "name": "percentage",
      "type": "number",
      "label": "进度最多百分比",
      "default": 100,
      "min": 0,
      "max": 100,
      "step": 1
    },
    {
      "name": "height",
      "type": "number",
      "label": "进度条高度",
      "default": 20,
      "min": 5,
      "max": 100,
      "step": 1
    },
    {
      "name": "color",
      "type": "color",
      "label": "进度条颜色",
      "default": "#4CAF50"
    },
    {
      "name": "bg_color",
      "type": "color",
      "label": "背景颜色",
      "default": "#f0f0f0"
    },
    {
      "name": "border_radius",
      "type": "number",
      "label": "圆角大小",
      "default": 4,
      "min": 0,
      "max": 50,
      "step": 1
    },
    {
      "name": "show_text",
      "type": "boolean",
      "label": "显示百分比文本",
      "default": true
    },
    {
      "name": "hide_after_animation",
      "type": "boolean",
      "label": "动画完成后隐藏",
      "default": false
    },
    {
      "name": "animation_duration",
      "type": "number",
      "label": "动画持续时间(秒)",
      "default": 0.3,
      "min": 0.1,
      "max": 10,
      "step": 0.1
    }
  ]
}