<Window x:Class="PyHTML.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:PyHTML.WPF.ViewModels"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Height="850"
        Width="1500"
        MinHeight="650"
        MinWidth="1100"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource Win11WindowStyle}">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <!-- 主窗口背景 - 白色 + 圆角 -->
    <Border Background="{StaticResource WindowBackgroundBrush}"
            CornerRadius="12"
            BorderBrush="{StaticResource BorderLightBrush}"
            BorderThickness="1"
            Effect="{StaticResource WindowShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar - Win11 风格 -->
            <Border Grid.Row="0" 
                    Style="{StaticResource Win11TitleBarStyle}"
                    CornerRadius="12,12,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Icon and Title -->
                    <StackPanel Grid.Column="0" 
                                Orientation="Horizontal" 
                                Margin="16,0">
                        <Border Background="{StaticResource PrimaryBrush}"
                                CornerRadius="6"
                                Width="28"
                                Height="28"
                                Margin="0,0,12,0">
                            <TextBlock Text="&#xE768;" 
                                       FontFamily="Segoe MDL2 Assets"
                                       Foreground="White"
                                       FontSize="14"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{Binding WindowTitle}"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"
                                   FontSize="14"
                                   FontWeight="SemiBold"/>
                    </StackPanel>

                    <!-- Window Controls - Win11 风格 -->
                    <StackPanel Grid.Column="2" 
                                Orientation="Horizontal">
                        <Button x:Name="MinimizeButton"
                                Content="&#xE921;"
                                FontFamily="Segoe MDL2 Assets"
                                Style="{StaticResource Win11ToolButtonStyle}"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Width="46"
                                Height="32"
                                FontSize="10"
                                Click="MinimizeButton_Click"/>
                        <Button x:Name="MaximizeButton"
                                Content="&#xE922;"
                                FontFamily="Segoe MDL2 Assets"
                                Style="{StaticResource Win11ToolButtonStyle}"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Width="46"
                                Height="32"
                                FontSize="10"
                                Click="MaximizeButton_Click"/>
                        <Button x:Name="CloseButton"
                                Content="&#xE711;"
                                FontFamily="Segoe MDL2 Assets"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Width="46"
                                Height="32"
                                FontSize="10"
                                Click="CloseButton_Click">
                            <Button.Style>
                                <Style BasedOn="{StaticResource Win11ToolButtonStyle}" TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#E81123"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Menu Bar - 简洁风格 -->
            <Border Grid.Row="1" 
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderLightBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="12,4">
                <Menu Style="{StaticResource Win11MenuStyle}">
                    <MenuItem Header="文件">
                        <MenuItem Header="新建项目" 
                                  Command="{Binding CreateNewProjectCommand}"
                                  InputGestureText="Ctrl+N"/>
                        <MenuItem Header="打开项目" 
                                  Command="{Binding OpenProjectCommand}"
                                  InputGestureText="Ctrl+O"/>
                        <Separator/>
                        <MenuItem Header="保存" 
                                  Command="{Binding SaveProjectCommand}"
                                  InputGestureText="Ctrl+S"/>
                        <MenuItem Header="另存为..." 
                                  Command="{Binding SaveProjectAsCommand}"
                                  InputGestureText="Ctrl+Shift+S"/>
                        <Separator/>
                        <MenuItem Header="导出HTML" 
                                  Command="{Binding ExportHtmlCommand}"
                                  InputGestureText="Ctrl+E"/>
                        <Separator/>
                        <MenuItem Header="退出" 
                                  Command="{Binding ExitCommand}"/>
                    </MenuItem>
                    <MenuItem Header="编辑">
                        <MenuItem Header="撤销" InputGestureText="Ctrl+Z" IsEnabled="False"/>
                        <MenuItem Header="重做" InputGestureText="Ctrl+Y" IsEnabled="False"/>
                        <Separator/>
                        <MenuItem Header="剪切" InputGestureText="Ctrl+X" IsEnabled="False"/>
                        <MenuItem Header="复制" InputGestureText="Ctrl+C" IsEnabled="False"/>
                        <MenuItem Header="粘贴" InputGestureText="Ctrl+V" IsEnabled="False"/>
                        <MenuItem Header="删除" InputGestureText="Delete" IsEnabled="False"/>
                    </MenuItem>
                    <MenuItem Header="视图">
                        <MenuItem Header="预览面板" 
                                  IsCheckable="True"
                                  IsChecked="{Binding IsPreviewVisible}"
                                  Command="{Binding TogglePreviewCommand}"/>
                        <Separator/>
                        <MenuItem Header="刷新预览" InputGestureText="F5" IsEnabled="False"/>
                    </MenuItem>
                    <MenuItem Header="AI助手">
                        <MenuItem Header="打开AI对话" Command="{Binding OpenAIDialogCommand}"/>
                        <MenuItem Header="AI配置" Command="{Binding OpenAIConfigCommand}"/>
                        <Separator/>
                        <MenuItem Header="生成网页" IsEnabled="False"/>
                        <MenuItem Header="优化当前组件" IsEnabled="False"/>
                    </MenuItem>
                    <MenuItem Header="图片">
                        <MenuItem Header="图片设置" Command="{Binding OpenImageSettingsCommand}"/>
                        <MenuItem Header="图片管理" Command="{Binding OpenImageManagerCommand}"/>
                        <Separator/>
                        <MenuItem Header="AI图片生成" IsEnabled="False"/>
                    </MenuItem>
                    <MenuItem Header="部署">
                        <MenuItem Header="部署到Cloudflare" Command="{Binding OpenDeployWindowCommand}"/>
                        <MenuItem Header="Worker配置" IsEnabled="False"/>
                    </MenuItem>
                    <MenuItem Header="设置">
                        <MenuItem Header="Head设置" Command="{Binding OpenHeadSettingsCommand}"/>
                        <MenuItem Header="背景图片设置" Command="{Binding OpenBackgroundSettingsCommand}"/>
                        <MenuItem Header="主题设置" Command="{Binding OpenThemeSettingsCommand}"/>
                    </MenuItem>
                    <MenuItem Header="帮助">
                        <MenuItem Header="使用说明" Command="{Binding OpenHelpWindowCommand}"/>
                        <MenuItem Header="快捷键" Command="{Binding OpenShortcutsWindowCommand}"/>
                        <Separator/>
                        <MenuItem Header="关于" 
                                  Command="{Binding ShowAboutCommand}"/>
                    </MenuItem>
                </Menu>
            </Border>

            <!-- Main Content - 卡片式布局 -->
            <Grid Grid.Row="2" Margin="16,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280" MinWidth="220"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*" MinWidth="400"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="320" MinWidth="260"/>
                </Grid.ColumnDefinitions>

                <!-- Component Library Panel - 卡片样式 -->
                <Border Grid.Column="0" 
                        Style="{StaticResource Win11CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Panel Header -->
                        <TextBlock Grid.Row="0"
                                   Text="组件库"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="0,0,0,12"/>

                        <!-- Category Filter -->
                        <ComboBox Grid.Row="1"
                                  Margin="0,0,0,12"
                                  ItemsSource="{Binding ComponentLibrary.Categories}"
                                  SelectedItem="{Binding ComponentLibrary.SelectedCategory}"
                                  Style="{StaticResource Win11ComboBoxStyle}"
                                  DisplayMemberPath="."/>

                        <!-- Component List -->
                        <ListBox Grid.Row="2"
                                 ItemsSource="{Binding ComponentLibrary.FilteredComponents}"
                                 Style="{StaticResource Win11ListBoxStyle}"
                                 ItemContainerStyle="{StaticResource Win11ListBoxItemStyle}"
                                 MouseDoubleClick="ComponentLibrary_MouseDoubleClick">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="{Binding DisplayName}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{Binding Description}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <!-- Splitter 1 -->
                <GridSplitter Grid.Column="1" 
                              Style="{StaticResource Win11GridSplitterStyle}"/>

                <!-- Page Editor Panel - 卡片样式 -->
                <Border Grid.Column="2" 
                        Style="{StaticResource Win11CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Panel Header -->
                        <TextBlock Grid.Row="0"
                                   Text="{Binding ProjectName, StringFormat='页面编辑 - {0}'}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="0,0,0,12"/>

                        <!-- Component List -->
                        <ListBox Grid.Row="1"
                                 ItemsSource="{Binding PageComponents}"
                                 SelectedItem="{Binding SelectedComponent}"
                                 Style="{StaticResource Win11ListBoxStyle}"
                                 ItemContainerStyle="{StaticResource Win11ListBoxItemStyle}"
                                 AllowDrop="True">
                            <ListBox.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="复制 (Ctrl+C)" 
                                              Command="{Binding CopyComponentCommand}"
                                              IsEnabled="{Binding SelectedComponent, Converter={StaticResource NullToBooleanConverter}}"/>
                                    <MenuItem Header="粘贴 (Ctrl+V)" 
                                              Command="{Binding PasteComponentCommand}"
                                              IsEnabled="{Binding CopiedComponent, Converter={StaticResource NullToBooleanConverter}}"/>
                                    <Separator/>
                                    <MenuItem Header="删除 (Delete)" 
                                              Command="{Binding RemoveComponentCommand}"
                                              CommandParameter="{Binding SelectedComponent}"
                                              IsEnabled="{Binding SelectedComponent, Converter={StaticResource NullToBooleanConverter}}"/>
                                </ContextMenu>
                            </ListBox.ContextMenu>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding Category}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" 
                                                    Orientation="Horizontal">
                                            <Button Content="&#xE70E;"
                                                    FontFamily="Segoe MDL2 Assets"
                                                    Style="{StaticResource Win11ToolButtonStyle}"
                                                    Padding="6,4"
                                                    Command="{Binding DataContext.MoveComponentUpCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Content="&#xE70D;"
                                                    FontFamily="Segoe MDL2 Assets"
                                                    Style="{StaticResource Win11ToolButtonStyle}"
                                                    Padding="6,4"
                                                    Margin="4,0,0,0"
                                                    Command="{Binding DataContext.MoveComponentDownCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Content="&#xE711;"
                                                    FontFamily="Segoe MDL2 Assets"
                                                    Style="{StaticResource Win11ToolButtonStyle}"
                                                    Padding="6,4"
                                                    Margin="4,0,0,0"
                                                    Command="{Binding DataContext.RemoveComponentCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- Action Buttons -->
                        <StackPanel Grid.Row="2" 
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Margin="0,16,0,0">
                            <Button Content="添加组件"
                                    Style="{StaticResource Win11PrimaryButtonStyle}"
                                    Command="{Binding AddComponentCommand}"
                                    CommandParameter="{Binding ComponentLibrary.FilteredComponents/}"/>
                            <Button Content="预览"
                                    Style="{StaticResource Win11SecondaryButtonStyle}"
                                    Margin="12,0,0,0"
                                    Command="{Binding TogglePreviewCommand}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Splitter 2 -->
                <GridSplitter Grid.Column="3" 
                              Style="{StaticResource Win11GridSplitterStyle}"/>

                <!-- Property Editor Panel - 卡片样式 -->
                <Border Grid.Column="4" 
                        Style="{StaticResource Win11CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Panel Header -->
                        <TextBlock Grid.Row="0"
                                   Text="属性编辑"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="0,0,0,12"/>

                        <!-- Properties Content -->
                        <ScrollViewer Grid.Row="1" 
                                      Style="{StaticResource Win11ScrollViewerStyle}">
                            <StackPanel>
                                <TextBlock Text="请选择一个组件以编辑属性"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           Visibility="{Binding SelectedComponent, Converter={StaticResource NullToVisibilityConverter}}"/>

                                <ItemsControl ItemsSource="{Binding SelectedComponent.PropertyItems}"
                                              Visibility="{Binding SelectedComponent, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverted}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,8">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <TextBlock Grid.Row="0"
                                                           Text="{Binding DisplayName}"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           Margin="0,0,0,2"/>
                                                <TextBlock Grid.Row="0"
                                                           Text="{Binding Key}"
                                                           FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           Margin="0,0,0,6"
                                                           Opacity="0.7"/>
                                                <TextBox Grid.Row="1"
                                                         Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource Win11TextBoxStyle}"
                                                         ToolTip="{Binding Description}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <!-- Status Bar - Win11 风格 -->
            <Border Grid.Row="3" 
                    Background="{StaticResource SurfaceSecondaryBrush}"
                    BorderBrush="{StaticResource BorderLightBrush}"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,12,12"
                    Padding="16,10">
                <Grid>
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding PageComponents.Count, StringFormat='组件数: {0}'}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
